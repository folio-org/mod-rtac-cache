{
  "id": "@artifactId@-@version@",
  "name": "Fetches real time availability information from FOLIO for instances, items and holdings.",
  "provides": [
    {
      "id": "rtac-cache",
      "version": "1.0",
      "handlers": [
        {
          "methods": [ "GET" ],
          "pathPattern": "/rtac-cache/{id}",
          "permissionsRequired": [ "rtac-cache.collection.get" ],
          "modulePermissions":[
            "inventory-storage.instances.collection.get",
            "inventory-storage.items.retrieve.collection.post",
            "inventory-storage.holdings.retrieve.collection.post",
            "inventory-storage.location-units.libraries.collection.get",
            "inventory-storage.locations.collection.get",
            "inventory-storage.material-types.collection.get",
            "inventory-storage.loan-types.collection.get",
            "inventory-storage.holdings-note-types.collection.get",
            "inventory-storage.bound-with-parts.collection.get",
            "circulation-storage.loans.collection.get",
            "circulation.requests.collection.get",
            "orders-storage.pieces.collection.get",
            "user-tenants.collection.get",
            "consortium-search.holdings.batch.collection.get"
          ]
        },
        {
          "methods": [ "POST" ],
          "pathPattern": "/rtac-cache/batch",
          "permissionsRequired": [ "rtac-cache.batch.collection.post" ],
          "modulePermissions":[
            "inventory-storage.instances.collection.get",
            "inventory-storage.items.retrieve.collection.post",
            "inventory-storage.holdings.retrieve.collection.post",
            "inventory-storage.location-units.libraries.collection.get",
            "inventory-storage.locations.collection.get",
            "inventory-storage.material-types.collection.get",
            "inventory-storage.loan-types.collection.get",
            "inventory-storage.holdings-note-types.collection.get",
            "inventory-storage.bound-with-parts.collection.get",
            "circulation-storage.loans.collection.get",
            "circulation.requests.collection.get",
            "orders-storage.pieces.collection.get",
            "user-tenants.collection.get",
            "consortium-search.holdings.batch.collection.get"
          ]
        },
        {
          "methods": [
            "GET"
          ],
          "pathPattern": "/rtac-cache/search/{instanceId}",
          "permissionsRequired": [
            "rtac-cache.search.collection.get"
          ],
          "modulePermissions": [
            "inventory-storage.instances.collection.get",
            "inventory-storage.items.retrieve.collection.post",
            "inventory-storage.holdings.retrieve.collection.post",
            "inventory-storage.location-units.libraries.collection.get",
            "inventory-storage.locations.collection.get",
            "inventory-storage.material-types.collection.get",
            "inventory-storage.loan-types.collection.get",
            "inventory-storage.holdings-note-types.collection.get",
            "inventory-storage.bound-with-parts.collection.get",
            "circulation-storage.loans.collection.get",
            "circulation.requests.collection.get",
            "orders-storage.pieces.collection.get",
            "user-tenants.collection.get",
            "consortium-search.holdings.batch.collection.get"
          ]
        },
        {
          "methods": [ "GET" ],
          "pathPattern": "/rtac-cache/prewarm",
          "permissionsRequired": [ "rtac-cache.prewarm.collection.get" ]
        },
        {
          "methods": [ "GET" ],
          "pathPattern": "/rtac-cache/prewarm/{id}",
          "permissionsRequired": [ "rtac-cache.prewarm.get" ]
        },
        {
          "methods": [ "POST" ],
          "pathPattern": "/rtac-cache/prewarm",
          "permissionsRequired": [ "rtac-cache.prewarm.post" ]
        },
        {
          "methods": [ "POST" ],
          "pathPattern": "/rtac-cache/invalidate",
          "permissionsRequired": [ "rtac-cache.invalidate.post" ]
        },
        {
          "methods": [ "POST" ],
          "pathPattern": "/rtac-cache/invalidate-all",
          "permissionsRequired": [ "rtac-cache.invalidate-all.post" ]
        }
      ]
    },
    {
      "id": "_tenant",
      "version": "2.0",
      "interfaceType": "system",
      "handlers": [
        {
          "methods": ["POST"],
          "pathPattern": "/_/tenant"
        }, {
          "methods": [
            "DELETE", "GET"
          ],
          "pathPattern": "/_/tenant/{id}"
        }
      ]
    }
  ],
  "requires": [
    {
      "id": "item-storage",
      "version": "11.2"
    },
    {
      "id": "holdings-storage",
      "version": "8.2"
    },
    {
      "id": "instance-storage",
      "version": "11.3"
    },
    {
      "id": "loan-types",
      "version": "2.4"
    },
    {
      "id": "material-types",
      "version": "2.2"
    },
    {
      "id": "location-units",
      "version": "2.1"
    },
    {
      "id": "locations",
      "version": "3.2"
    },
    {
      "id": "holdings-note-types",
      "version": "1.0"
    },
    {
      "id": "loan-storage",
      "version": "7.4"
    },
    {
      "id": "circulation",
      "version": "14.7"
    },
    {
      "id": "orders-storage.pieces",
      "version": "5.0"
    },
    {
      "id": "user-tenants",
      "version": "1.0"
    },
    {
      "id": "settings",
      "version": "1.2"
    },
    {
      "id": "bound-with-parts-storage",
      "version": "2.0"
    }
  ],
  "optional": [
    {
      "id": "consortia",
      "version": "1.1"
    },
    {
      "id": "consortium-search",
      "version": "2.1"
    }
  ],
  "permissionSets": [
    {
      "permissionName": "rtac-cache.collection.get",
      "displayName": "RTAC Cache - Get collection",
      "description": "Get RTAC cache collection"
    },
    {
      "permissionName": "rtac-cache.batch.collection.post",
      "displayName": "RTAC Cache - Post batch collection",
      "description": "Post RTAC cache batch collection"
    },
    {
      "permissionName": "rtac-cache.search.collection.get",
      "displayName": "RTAC Cache - Collection search",
      "description": "RTAC cache search collection"
    },
    {
      "permissionName": "rtac-cache.all",
      "displayName": "RTAC Cache - All permissions",
      "description": "All RTAC cache permissions"
    },
    {
      "permissionName": "rtac-cache.prewarm.collection.get",
      "displayName": "RTAC Cache - Get collection of pre-warming jobs",
      "description": "Get RTAC cache pre-warming jobs collection"
    },
    {
      "permissionName": "rtac-cache.prewarm.get",
      "displayName": "RTAC Cache - Get pre-warming job status",
      "description": "Get RTAC cache pre-warming job status by ID"
    },
    {
      "permissionName": "rtac-cache.prewarm.post",
      "displayName": "RTAC Cache - Submit pre-warming job",
      "description": "Submit RTAC cache pre-warming job"
    },
    {
      "permissionName": "rtac-cache.invalidate.post",
      "displayName": "RTAC Cache - Invalidate cache entries",
      "description": "Invalidate RTAC cache entries by instance IDs"
    },
    {
      "permissionName": "rtac-cache.invalidate-all.post",
      "displayName": "RTAC Cache - Invalidate all cache entries",
      "description": "Invalidate all RTAC cache entries"
    },
    {
      "permissionName": "rtac-cache.all",
      "displayName": "RTAC Cache - All permissions",
      "description": "All RTAC cache permissions",
      "subPermissions": [
        "rtac-cache.collection.get",
        "rtac-cache.batch.collection.post",
        "rtac-cache.search.collection.get",
        "rtac-cache.prewarm.collection.get",
        "rtac-cache.prewarm.get",
        "rtac-cache.prewarm.post",
        "rtac-cache.invalidate.post",
        "rtac-cache.invalidate-all.post"
          ]
    }
  ],
  "metadata": {
    "user": {
      "type": "system",
      "permissions": [
        "inventory-storage.instances.collection.get",
        "inventory-storage.items.retrieve.collection.post",
        "inventory-storage.holdings.retrieve.collection.post",
        "inventory-storage.location-units.libraries.collection.get",
        "inventory-storage.locations.collection.get",
        "inventory-storage.bound-with-parts.collection.get",
        "inventory-storage.material-types.collection.get",
        "inventory-storage.loan-types.collection.get",
        "inventory-storage.holdings-note-types.collection.get",
        "circulation-storage.loans.collection.get",
        "circulation.requests.collection.get",
        "orders-storage.pieces.collection.get",
        "user-tenants.collection.get",
        "consortium-search.holdings.batch.collection.get"
      ]
    }
  },
  "env": [
    {
      "name": "JAVA_OPTIONS",
      "value": "-XX:MaxRAMPercentage=66.0",
      "required": false,
      "description": "JVM options passed to the Java process. The default reserves 66% of container memory for the heap."
    },
    {
      "name": "DB_HOST",
      "value": "postgres",
      "required": false,
      "description": "PostgreSQL host used by the Spring datasource JDBC URL."
    },
    {
      "name": "DB_PORT",
      "value": "5432",
      "required": false,
      "description": "PostgreSQL port used by the Spring datasource JDBC URL."
    },
    {
      "name": "DB_USERNAME",
      "value": "folio_admin",
      "required": false,
      "description": "PostgreSQL username used by the module datasource."
    },
    {
      "name": "DB_PASSWORD",
      "value": "",
      "required": true,
      "description": "Password for DB_USERNAME."
    },
    {
      "name": "DB_DATABASE",
      "value": "okapi_modules",
      "required": false,
      "description": "PostgreSQL database name used by the module datasource."
    },
    {
      "name": "DB_QUERYTIMEOUT",
      "value": "60000",
      "required": false,
      "description": "PostgreSQL statement timeout in milliseconds applied to Hikari connections by folio-spring-base when set."
    },
    {
      "name": "DB_CHARSET",
      "value": "UTF-8",
      "required": false,
      "description": "PostgreSQL connection character encoding applied to Hikari connections by folio-spring-base."
    },
    {
      "name": "DB_MAXPOOLSIZE",
      "value": "5",
      "required": false,
      "description": "Legacy FOLIO maximum database pool-size setting kept for descriptor compatibility; this Spring runtime uses DB_MAXSHAREDPOOLSIZE for Hikari maximum pool size."
    },
    {
      "name": "KAFKA_HOST",
      "value": "localhost",
      "required": false,
      "description": "Kafka broker host used to build spring.kafka.bootstrap-servers."
    },
    {
      "name": "KAFKA_PORT",
      "value": "9092",
      "required": false,
      "description": "Kafka broker port used to build spring.kafka.bootstrap-servers."
    },
    {
      "name": "KAFKA_MAX_POLL_RECORDS",
      "value": "50",
      "required": false,
      "description": "Maximum number of Kafka records returned in a single consumer poll."
    },
    {
      "name": "KAFKA_SECURITY_PROTOCOL",
      "value": "PLAINTEXT",
      "required": false,
      "description": "Kafka client security protocol; common values are PLAINTEXT, SSL, SASL_PLAINTEXT, and SASL_SSL."
    },
    {
      "name": "KAFKA_SSL_KEYSTORE_PASSWORD",
      "value": "",
      "required": false,
      "description": "Password for the Kafka SSL key store when SSL client authentication is configured."
    },
    {
      "name": "KAFKA_SSL_KEYSTORE_LOCATION",
      "value": "",
      "required": false,
      "description": "Filesystem path to the Kafka SSL key store when SSL client authentication is configured."
    },
    {
      "name": "KAFKA_SSL_TRUSTSTORE_PASSWORD",
      "value": "",
      "required": false,
      "description": "Password for the Kafka SSL trust store when SSL is configured."
    },
    {
      "name": "KAFKA_SSL_TRUSTSTORE_LOCATION",
      "value": "",
      "required": false,
      "description": "Filesystem path to the Kafka SSL trust store when SSL is configured."
    },
    {
      "name": "ENV",
      "value": "folio",
      "required": false,
      "description": "Logical FOLIO deployment name used as the prefix for Kafka topic patterns and Kafka consumer groups."
    },
    {
      "name": "OKAPI_URL",
      "value": "",
      "required": true,
      "description": "Okapi base URL used for outbound FOLIO service calls and system-user requests. Must be provided by the deployment environment."
    },
    {
      "name": "KAFKA_RETRY_INTERVAL_MS",
      "value": "2000",
      "required": false,
      "description": "Interval in milliseconds between Kafka message delivery retry attempts."
    },
    {
      "name": "KAFKA_RETRY_DELIVERY_ATTEMPTS",
      "value": "6",
      "required": false,
      "description": "Maximum number of Kafka message delivery attempts before retry handling is exhausted."
    },
    {
      "name": "KAFKA_EVENTS_CONCURRENCY",
      "value": "2",
      "required": false,
      "description": "Number of concurrent consumers configured for each RTAC cache Kafka listener."
    },
    {
      "name": "KAFKA_EVENTS_CONSUMER_PATTERN",
      "value": "",
      "required": false,
      "description": "Optional topic-pattern override for all RTAC cache Kafka listeners. Leave empty to use the per-entity default patterns based on ENV."
    },
    {
      "name": "SYSTEM_USER_ENABLED",
      "value": "false",
      "required": false,
      "description": "Enables legacy Okapi system-user token retrieval for Kafka and background downstream module calls. Leave false for Eureka deployments where sidecars provide module-to-module system tokens."
    },
    {
      "name": "SYSTEM_USER_USERNAME",
      "value": "mod-rtac-cache",
      "required": false,
      "description": "Username for the legacy Okapi module system user when SYSTEM_USER_ENABLED is true."
    },
    {
      "name": "SYSTEM_USER_PASSWORD",
      "value": "",
      "required": false,
      "description": "Password for the legacy Okapi module system user; required only when SYSTEM_USER_ENABLED is true in classic Okapi deployments."
    },
    {
      "name": "RTAC_CACHE_INVALIDATION_CRON",
      "value": "0 0 2 * * ?",
      "required": false,
      "description": "Spring cron expression for the scheduled purge of stale rtac_holding cache rows."
    },
    {
      "name": "RTAC_CACHE_RETENTION_DAYS",
      "value": "2",
      "required": false,
      "description": "Number of days to retain cached RTAC holdings before the scheduled invalidation job deletes them."
    }
  ],
  "launchDescriptor": {
    "dockerImage": "@artifactId@:@version@",
    "dockerPull": false,
    "dockerArgs": {
      "HostConfig": {
        "Memory": 357913941,
        "PortBindings": { "8081/tcp": [ { "HostPort": "%p" } ] }
      }
    },
    "env": [
      { "name": "JAVA_OPTIONS",
        "value": "-XX:MaxRAMPercentage=66.0"
      },
      { "name": "DB_HOST", "value": "postgres" },
      { "name": "DB_PORT", "value": "5432" },
      { "name": "DB_USERNAME", "value": "folio_admin" },
      { "name": "DB_PASSWORD", "value": "" },
      { "name": "DB_DATABASE", "value": "okapi_modules" },
      { "name": "DB_QUERYTIMEOUT", "value": "60000" },
      { "name": "DB_CHARSET", "value": "UTF-8" },
      { "name": "DB_MAXPOOLSIZE", "value": "5" },
      { "name": "KAFKA_HOST", "value": "localhost" },
      { "name": "KAFKA_PORT", "value": "9092" },
      { "name": "KAFKA_MAX_POLL_RECORDS", "value": "50" },
      { "name": "KAFKA_SECURITY_PROTOCOL", "value": "PLAINTEXT" },
      { "name": "KAFKA_SSL_KEYSTORE_PASSWORD", "value": "" },
      { "name": "KAFKA_SSL_KEYSTORE_LOCATION", "value": "" },
      { "name": "KAFKA_SSL_TRUSTSTORE_PASSWORD", "value": "" },
      { "name": "KAFKA_SSL_TRUSTSTORE_LOCATION", "value": "" },
      { "name": "ENV", "value": "folio" },
      { "name": "OKAPI_URL", "value": "" },
      { "name": "KAFKA_RETRY_INTERVAL_MS", "value": "2000" },
      { "name": "KAFKA_RETRY_DELIVERY_ATTEMPTS", "value": "6" },
      { "name": "KAFKA_EVENTS_CONCURRENCY", "value": "2" },
      { "name": "KAFKA_EVENTS_CONSUMER_PATTERN", "value": "" },
      { "name": "SYSTEM_USER_ENABLED", "value": "false" },
      { "name": "SYSTEM_USER_USERNAME", "value": "mod-rtac-cache" },
      { "name": "SYSTEM_USER_PASSWORD", "value": "" },
      { "name": "RTAC_CACHE_INVALIDATION_CRON", "value": "0 0 2 * * ?" },
      { "name": "RTAC_CACHE_RETENTION_DAYS", "value": "2" }
    ]
  }
}
